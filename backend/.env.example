# Copy this file to .env and fill in the values
# Never commit .env to version control

# PostgreSQL async connection string
# postgresql+asyncpg:// → asyncpg sürücüsünü kullan (async için gerekli)
# Lokal geliştirme    : @localhost:5432
# Docker Compose      : @db:5432  (servis adı kullanılır)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/yorum_analizi

# Get your Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
